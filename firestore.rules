rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Movies collection rules
    match /movies/{movieId} {
      // General viewers can query and browse the catalog
      allow read: if true;
      // Admin client performs writes, updates, and deletes
      allow write: if true;
    }

    // Requests collection rules
    match /requests/{requestId} {
      // General viewers can read/write requests ledger
      allow read, write: if true;
    }

    // Series collection rules
    match /series/{seriesId} {
      // General viewers can read/write series catalog
      allow read, write: if true;
    }

    // Notifications collection rules
    match /notifications/{notificationId} {
      // General viewers can read/write their notifications
      allow read, write: if true;
    }
  }
}
